# Copy to .env and fill in. The pipeline reads these at runtime.

# --- LLM provider (swappable) ---
# FREE option (recommended): Google Gemini free tier. Key: aistudio.google.com -> "Get API key".
LLM_PROVIDER=google            # google | gemini | openai
LLM_MODEL=gemini-2.0-flash     # free-tier model; also: gemini-2.5-flash, gemini-1.5-flash
GOOGLE_API_KEY=AIza...         # <-- your Gemini key goes here
#
# PAID option: OpenAI (no free tier, but gpt-4o-mini costs pennies per scan).
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...

# --- Web search (the "eyes" — LLMs can't browse on their own) ---
# Tavily free tier: ~1,000 searches/mo, no card. Key: app.tavily.com
SEARCH_BACKEND=tavily          # tavily | none
TAVILY_API_KEY=tvly-...        # <-- your Tavily key goes here

# --- Pipeline tunables (see config.py) ---
T_SETTLE_DAYS=7                # events newer than this are held as provisional
N_MIN_SOURCES=2               # independent sources required to corroborate
AUTO_APPROVE_CONFIDENCE=0.8   # >= this + all-pass -> auto-approve queue (less human review)

# --- Paths ---
SEED_JSON=../src/data/seed.json   # the app dataset we resolve against / propose into
OUTPUT_DIR=./out                  # proposals + review queue land here
