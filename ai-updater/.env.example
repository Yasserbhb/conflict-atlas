# Copy to .env and fill in. The pipeline reads these at runtime.

# --- LLM provider (swappable) ---
LLM_PROVIDER=openai            # openai | (any langchain provider you wire in llm.py)
LLM_MODEL=gpt-4o-mini          # cheap default; use a stronger model for the reconciler if you like
OPENAI_API_KEY=sk-...

# --- Web search ---
SEARCH_BACKEND=tavily          # tavily | none
TAVILY_API_KEY=tvly-...

# --- Pipeline tunables (see config.py) ---
T_SETTLE_DAYS=7                # events newer than this are held as provisional
N_MIN_SOURCES=2               # independent sources required to corroborate
AUTO_APPROVE_CONFIDENCE=0.8   # >= this + all-pass -> auto-approve queue (less human review)

# --- Paths ---
SEED_JSON=../src/data/seed.json   # the app dataset we resolve against / propose into
OUTPUT_DIR=./out                  # proposals + review queue land here
